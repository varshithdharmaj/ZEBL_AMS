# Copy to .env and fill in values. Never commit real secrets.

DATABASE_URL=
AUTH_SECRET=

# Initial Super Admin bootstrap (optional; run: npm run db:bootstrap-admin).
# Idempotent — no-ops if an active Super Admin already exists. Never assigned via SSO.
INITIAL_SUPER_ADMIN_EMAIL=
INITIAL_SUPER_ADMIN_PASSWORD=

# Public URL for emails/OAuth. Optional on Vercel — VERCEL_URL is used automatically.
APP_BASE_URL=http://localhost:3000

# Vercel production example (no custom domain):
# APP_BASE_URL=https://your-project.vercel.app

# SMTP (optional for email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Cron/worker auth (production recommended)
NOTIFICATION_CRON_SECRET=
INTEGRATION_CRON_SECRET=
ANALYTICS_CRON_SECRET=

# Approval email tokens (optional; falls back to AUTH_SECRET)
APPROVAL_TOKEN_SECRET=
APPROVAL_TOKEN_TTL_HOURS=72

# Microsoft Entra ID (OAuth 2.0 + PKCE)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
AUTH_SSO_AUTO_LINK=true
AUTH_SSO_AUTO_PROVISION=false
AZURE_AD_GROUP_ROLE_MAP={}
AZURE_AD_APP_ROLE_MAP={}

# Microsoft Graph (calendar, org sync)
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# Teams incoming webhook
TEAMS_WEBHOOK_URL=
TEAMS_CALLBACK_SECRET=
CALENDAR_TIMEZONE=India Standard Time

# Neon example (paste from dashboard; include ?sslmode=require):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Supabase connection example (db.ltkjnppndnkweatdzntz.supabase.co):
# Direct (port 5432, for migrations): postgresql://postgres:[YOUR-PASSWORD]@db.ltkjnppndnkweatdzntz.supabase.co:5432/postgres
# Transaction Pooler (port 6543, for serverless app): postgresql://postgres.ltkjnppndnkweatdzntz:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
